# ── LLM ───────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=chromatic-being-375320
DATABASE_ID=linkedin-api

# ── API (local dev only) ──────────────────────────────────────────────────────
# Any string works locally — must match what the frontend sends
API_KEY=local-dev-key

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to "true" to hide the browser window (required on VMs / Cloud Run)
HEADLESS=false

# ── Worker identity ───────────────────────────────────────────────────────────
# Unique name for this machine — shows up in Firestore so you know who ran a job
# e.g. arjun-mbp, sarah-mbp, office-mac
WORKER_NAME=your-name-here

# ── ngrok ─────────────────────────────────────────────────────────────────────
# Get authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# Your static domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=your-subdomain.ngrok.app
